package main

import "fmt"

func main() {
	const nval int = 5
	var (
		valor [nval]float64
		soma  float64 = 0
	)

	for i := 0; i < nval; i++ {
		fmt.Printf("Informe o valor N %d ", i)
		fmt.Scan(&valor[i])
		soma += valor[i]
	}

	for i, val := range valor {
		fmt.Printf("Valor %d e = %.2f\n", i, val)
	}

	fmt.Printf("A soma dos valores e %.2f\n", soma)
}
