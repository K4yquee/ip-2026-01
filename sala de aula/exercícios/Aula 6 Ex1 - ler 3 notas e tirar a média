package main

import "fmt"

func main() {
	const nnotas int = 3
	var (
		nota [nnotas]float64
		soma float64 = 0
	)

	for i := 0; i < nnotas; i++ {
		fmt.Printf("Informe a nota %d ", i)
		fmt.Scan(&nota[i])
		soma += nota[i]
	}

	for i, no := range nota {
		fmt.Printf("Nota %d = %f\n", i, no)
	}

	media := soma / 3
	fmt.Printf("A media das notas e %.2f ", media)

}
